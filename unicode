#!/usr/bin/env perl
use strict;
use Getopt::Std;
use Encode;

# ----------------------------------------------------------------------
# All fields in UnicodeData.txt, in the order they appear in each line.
my $file_fnames   = "codept,cname,ccat,comb,bidi,decomp,decval,digval,numval,mirror,oldname,cmt,ucmap,lcmap,titmap";

my $short_fnames = "char,codept,utf8,name";
my $med_fnames   = "char,codept,utf8,cat,ucmap,lcmap,titmap,name";
my $long_fnames  = "char,codept,utf8,cat,bidi,mirror,width,comb,ucmap,lcmap,titmap,decomp,decval,digval,numval,name";

my $usage = <<_EOF_;
usage: unicode [options] [selector]...
       Prints glyphs which match all selectors.
       Each selector is a comma-separated list of patterns, and
       a glyph matches the selector if it matches any of the patterns.
       A pattern is one of:
       1. A Unicode codepoint in the form U+xxxx or xxxx.
       2. A codepoint range in the form U+xxxx-U+yyyy or xxxx-yyyy.
       3. A regular expression in the form /pattern/ to match the name.
       By default, the output includes fields: $short_fnames.
   Options:
       -a          Print all chars, including non-printable ones.
       -h          Don't print header line.
       -l          Print more fields ($med_fnames).
       -L          Print all fields
                   ($long_fnames).
       -m          Multi-line output.
       -p FIELDS   Print only listed fields. Field may specify width after colon.
       -u FILE     Name of UnicodeData.txt file.
       -w FILE     Name of EastAsianWidth.txt file.
_EOF_

# ----------------------------------------------------------------------
# Properties of each field, used for formatting output.
my @field_info = (
    { 'fname' => 'bidi',    'width' => 3,  'title' => "bi", },
    { 'fname' => 'cat',     'width' => 2,  'title' => "ct", },
    { 'fname' => 'ccat',    'width' => 2,  'title' => "ct", },
    { 'fname' => 'cmt',     'width' => 40, 'title' => "comment", },
    { 'fname' => 'char',    'width' => 2,  'title' => "ch", },
    { 'fname' => 'cname',   'width' => 50, 'title' => "name", },
    { 'fname' => 'codept',  'width' => 5,  'title' => "code", },
    { 'fname' => 'comb',    'width' => 5,  'title' => "+", },
    { 'fname' => 'decomp',  'width' => 24, 'title' => "decomp", },
    { 'fname' => 'decval',  'width' => 1,  'title' => "d", },
    { 'fname' => 'digval',  'width' => 1,  'title' => "g", },
    { 'fname' => 'lcmap',   'width' => 5,  'title' => "lc", },
    { 'fname' => 'mirror',  'width' => 1,  'title' => "m", },
    { 'fname' => 'name',    'width' => 80, 'title' => "name/old name", },
    { 'fname' => 'numval',  'width' => 5,  'title' => "num", },
    { 'fname' => 'oldname', 'width' => 50, 'title' => "old name", },
    { 'fname' => 'titmap',  'width' => 5,  'title' => "title", },
    { 'fname' => 'ucmap',   'width' => 5,  'title' => "uc", },
    { 'fname' => 'utf8',    'width' => 11, 'title' => "utf-8", },
    { 'fname' => 'width',   'width' => 1,  'title' => "w", },
);

# Categories of non-printable characters in UnicodeData.
my %nonprint = (
    "Mc" => 1, # Mark, Spacing Combining
    "Me" => 1, # Mark, Enclosing
    "Mn" => 1, # Mark, Nonspacing
    "Cc" => 1, # Other, Control
    "Cf" => 1, # Other, Format
    "Co" => 1, # Other, Private Use
    "Cs" => 1, # Other, Surrogate
    "Xx" => 1, # (omit, internal use)
    "Zl" => 1, # Separator, Line
    "Zp" => 1, # Separator, Paragraph
);

# Bidi values of characters which should not be printed.
my %bad_bidi = (
    'R' => 1,  # Right-to-left
    'AL' => 1, # Arabic
    'AN' => 1, # Arabic Number
);

# Properties of wide characters in EastAsianWidth.
my %wide_prop = (
    'F' => 1,  # Fullwidth
    'W' => 1,  # Wide
);

my @force_omit = (
    [0xad,    0xad],    # SOFT HYPHEN
    [0x200d,  0x200d],  # ZERO WIDTH JOINER
    [0x1f3fb, 0x1f3ff], # EMOJI MODIFIER FITZPATRICK TYPE-[1-6]
    [0x1f9b0, 0x1f9b3], # EMOJI COMPONENT [RED,CURLY,BALD,WHITE] HAIR
    [0xfe00,  0xfe0f],  # VARIATION SELECTOR-[1-16]
    [0xe0100, 0xe01ef], # VARIATION SELECTOR-[17-256]
);
my $force_omit;

my @force_compose = (
    [0x1160, 0x11ff],
    [0xd7b0, 0xd7c6],
    [0xd7cb, 0xd7fb]
);
my $force_compose;

# ----------------------------------------------------------------------
exit (main() ? 0 : 1);

sub main {
    my %opt;
    die $usage if not getopts("ahlLmp:u:w:", \%opt);
    my $ufilename = ($opt{u} or progdir()."UnicodeData.txt");
    my $wfilename = ($opt{w} or progdir()."EastAsianWidth.txt");
    my $fnames = $opt{p} ? fnames($opt{p}) :
        $opt{L} ? $long_fnames : $opt{l} ? $med_fnames : $short_fnames;

    $force_compose = mktable(\@force_compose);
    $force_omit = mktable(\@force_omit);

    my $glyphs = read_unicode_file($ufilename);
    my $wfile = read_width_file($wfilename);
    return 0 if not $glyphs;
    print_header($fnames) if (not $opt{h} and not $opt{m});
    return search_unicode_file($glyphs, $wfile, $fnames, (not $opt{m}), $opt{a}, @ARGV);
}

# ----------------------------------------------------------------------
# Build a hash table from a list of codepoint ranges.
sub mktable {
    my ($ranges) = @_;
    my %table;
    foreach my $comp (@$ranges) {
        my ($lo,$hi) = @$comp;
        for (my $ch = $lo; $ch <= $hi; ++$ch) {
            $table{$ch} = 1;
        }
    }
    return \%table;
}

# ----------------------------------------------------------------------
# Read UnicodeData.txt and return a list of glyphs.
sub read_unicode_file {
    my ($file) = @_;
    my $fd;
    if (not open($fd, '<', $file)) {
        print "cannot open $file: $!\n";
        return undef;
    }
    my @glyphs;
    while (<$fd>) {
        chomp;
        my @fields = split /;/;
        my %glyph;
        my $codept = -1;
        my $index = 0;
        foreach my $fname (split /,/, $file_fnames) {
            my $field = $fields[$index++];
            if ($fname eq "codept") {
                $codept = hex($field);
            } elsif ($fname eq "ccat") {
                $glyph{cat} = $field;
                $field = "Mn" if $force_compose->{$codept};
                $field = "Xx" if $force_omit->{$codept};
            }
            $glyph{$fname} = $field;
        }
        push @glyphs, \%glyph;
    }
    close $fd;
    return \@glyphs;
}

# ----------------------------------------------------------------------
# Read EastAsianWidth.txt and return a hash mapping codepoints to widths.
sub read_width_file {
    my ($file) = @_;
    my $fd;
    if (not open($fd, '<', $file)) {
        print "cannot open $file: $!\n";
        return undef;
    }
    my %widths;
    while (<$fd>) {
        chomp;
        if (/^\s*([0-9A-Fa-f]+)(\.\.([0-9A-Fa-f]+))?\s*;\s*(\w+)/) {
            my $lo = hex($1);
            my $hi = defined($3) ? hex($3) : $lo;
            my $prop = $4;
            if ($wide_prop{$prop}) {
                for (my $ch = $lo; $ch <= $hi; ++$ch) {
                    $widths{$ch} = 2;
                }
            }
        }
    }
    close $fd;
    return \%widths;
}

# ----------------------------------------------------------------------
sub search_unicode_file {
    my $glyphs = shift @_;
    my $wfile = shift @_;
    my $fnames = shift @_;
    my $oneline = shift @_;
    my $all_print = shift @_;
    foreach my $glyph (@$glyphs) {
        if (glyph_match($glyph, @_)) {
            print_glyph($glyph, $wfile, $fnames, $oneline, $all_print);
        }
    }
}

# ----------------------------------------------------------------------
sub glyph_match {
    my $glyph = shift @_;
    foreach my $pat (@_) {
        return 0 if not glyph_match2($glyph, $pat);
    }
    return 1;
}
sub glyph_match2 {
    my ($glyph, $pat) = @_;
    foreach my $subpat (split /,/, $pat) {
        return 1 if glyph_match3($glyph, $subpat);
    }
    return 0;
}
sub glyph_match3 {
    my ($glyph, $pat) = @_;
    my $codept = hex($glyph->{codept});
    if ($pat =~ /^([uU]\+)?([0-9a-fA-F]+)-([uU]\+)?([0-9a-fA-F]+)/) {
        return ($codept >= hex($2) and $codept <= hex($4));
    }
    if ($pat =~ /^([uU]\+)?([0-9a-fA-F]+)/) {
        return (hex($2) == $codept);
    }
    if ($pat =~ m|^/(.*)/$|) {
        my $re = $1;
        return ($glyph->{cname} =~ /$re/i or $glyph->{oldname} =~ /$re/i);
    }
    die "invalid pattern: $pat\n";
}

# ----------------------------------------------------------------------
sub print_glyph {
    my ($glyph, $wfile, $fnames, $oneline, $all_print) = @_;
    my $utf8 = glyph_utf8($glyph);
    my $cw = glyph_width($glyph, $wfile);
    my @fnames = split /,/, $fnames;
    for (my $p = 0; $p < @fnames; ++$p) {
        my ($fname, $xx, $fwidth) = $fnames[$p] =~ /^([^:]+)(:(\d*))?$/;
        my $val = ($fname eq "char") ? $utf8 :
                  ($fname eq "utf8") ? bytes($utf8, length($utf8)) :
                  ($fname eq "width") ? $cw :
                  ($fname eq "name") ? "$glyph->{cname}" . (length($glyph->{oldname}) > 0 ? " / $glyph->{oldname}" : "") :
                  $glyph->{$fname};
        if ($oneline) {
            $fwidth = (($p+1 < @fnames) ? field_info($fname,'width') : 0) if not $fwidth;
            my $ps = $val;
            my $pw = ($fname eq "char") ? $cw : length($ps);
            if ($fwidth > 0 and $pw > $fwidth) {
                $ps = substr($ps, 0, $fwidth-1) . "…";
                $pw = $fwidth;
            }
            printf("%s", $ps) if ($pw > 0 or $all_print);
            printf("%-*s", $fwidth+1-$pw, '') if $pw < $fwidth+1;
        } elsif ($fname eq "char" and $cw == 0) {
            ;
        } else {
            printf "%-8s %s\n", $fname, $val if length($val) > 0;
        }
    }
    printf "\n";
}

# ----------------------------------------------------------------------
sub print_header {
    my ($fnames) = @_;
    foreach my $fnamed (split /,/, $fnames) {
        my ($fname, $xx, $width) = $fnamed =~ /^([^:]+)(:(\d*))?$/;
        $width = field_info($fname,'width') if not $width;
        if ($width) {
            my $title = uc(field_info($fname,'title'));
            printf "%-*s", $width+1, $title;
        }
    }
    printf "\n";
}

# ----------------------------------------------------------------------
sub glyph_utf8 {
    my ($glyph) = @_;
    return encode("UTF-8", chr(hex($glyph->{codept})));
}

# ----------------------------------------------------------------------
sub bytes {
    my ($s, $n) = @_;
    my $r = '';
    for (my $i = 0; $i < $n; ++$i) {
        my $b = $i < length($s) ? sprintf("%02x", ord(substr($s,$i,1))) : "  ";
        $r .= $b;
        $r .= " " if $i+1 < $n;
    }
    return $r;
}

# ----------------------------------------------------------------------
sub progdir {
    my ($dir) = $0 =~ m|^(.*/)[^/]*$|;
    $dir = "./" if length($dir) == 0;
    return $dir;
}

# ----------------------------------------------------------------------
sub glyph_width {
    my ($glyph, $wfile) = @_;
    return 0 if $nonprint{$glyph->{ccat}};
    return 0 if $bad_bidi{$glyph->{bidi}};
    my $w = $$wfile{hex $glyph->{codept}};
    return defined($w) ? $w : 1;
}

# ----------------------------------------------------------------------
sub fname {
    my ($fname) = @_;
    my $ret;
    foreach my $info (@field_info) {
        if (substr($info->{fname}, 0, length $fname) eq $fname) {
            die "ambiguous field name: $fname\n" if defined $ret;
            $ret = $info->{fname};
        }
    }
    die "unknown field name: $fname\n" if not defined $ret;
    return $ret;
}

# ----------------------------------------------------------------------
sub fnames {
    my ($fnames) = @_;
    my @ret;
    foreach my $fnamed (split /,/, $fnames) {
        my ($fname, $xx, $width) = $fnamed =~ /^([^:]+)(:(\d*))?$/;
        $fname = fname($fname);
        push @ret, defined($width) ? "$fname:$width" : $fname;
    }
    return join(",", @ret);
}

# ----------------------------------------------------------------------
sub field_info {
    my ($fname, $key) = @_;
    foreach my $info (@field_info) {
        return $info->{$key} if $info->{fname} eq $fname;
    }
    die "unknown field name: $fname\n";
}
